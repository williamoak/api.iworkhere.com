# === CockroachDB ===
DB_HOST=192.168.0.2
DB_HOSTNAME=api.iworkhere.com
DB_PORT=26257
DB_NAME=api
DB_USER=api
DB_CERT_DIR=/data/websites/iworkhere/certs.iworkhere.com/cockroach

HOST_IP=192.168.0.2

# === API Server Certificates ===
API_CERT_DIR=/data/websites/iworkhere/certs.iworkhere.com/api

# === Root CA for mTLS (used by API server for client cert verification) ===
ROOT_CA_CERT=/data/websites/iworkhere/certs.iworkhere.com/ca/ca.crt

NODE_ENV=development
DEBUG=false
API_VERSION=v1

MAX_CONCURRENT_REQUESTS=100

# ---------------------------------------------------------------------------
# @myDocBlock v2.2 Specification (for importing into ChatGPT or other projects)
# ---------------------------------------------------------------------------
# This standard defines a normalized, strict docblock format suitable for
# Swagger/OpenAPI generation, automated parsing, and consistent documentation.
#
# GENERAL RULES
# - Use standard /** */ docblock format.
# - Never nest multiline comments inside other multiline comments.
# - The following fields must appear in the exact order shown below.
# - requestExample, response, query, and requires must always contain valid JSON
#   when present (no placeholders, no ellipses, no pseudo-JSON).
# - Code language is never assumed; provide examples only in the language requested.
# - Author tag is always: @author william.r.oak@gmail.com
#
# REQUIRED FIELD ORDER
# 1. @file
# 2. @external
# 3. @module
# 4. @tag
# 5. @version
# 6. @author
# 7. @path
# 8. @summary
# 9. @description
# 10. @query            (NEW in v2.2, optional)
# 11. @requestExample
# 12. @response
# 13. @requires
#
# FIELD NOTES
# - @file:
#     File name or logical unit name.
#
# - @external:
#     Presence of this tag marks the file as eligible for public exposure.
#     The value is informational only; tooling checks for existence, not content.
#     Use "none" or omit the tag entirely for internal-only files.
#
# - @module:
#     Logical module name used for grouping.
#
# - @tag:
#     Swagger/OpenAPI tag used for endpoint grouping.
#
# - @version:
#     Semantic version of the endpoint or module.
#
# - @path:
#     HTTP route path for endpoints.
#     - Must start with "/"
#     - Must NOT include HTTP method
#     - Must NOT include hostname
#     Use "none" if the file is not an HTTP endpoint.
#
# - @summary:
#     Short description (1–2 sentences).
#
# - @description:
#     Longer explanation.
#     - Multi-line allowed
#     - No nested comments
#     - May describe resolution rules, precedence, or semantics
#
# - @query:   (v2.2)
#     JSON object declaring supported query parameters.
#     - Keys are query parameter names
#     - Values describe type, optionality, defaults, and meaning
#     - Declarative only; no behavior implied
#
#     Example:
#     {
#       "all": {
#         "type": "boolean",
#         "optional": true,
#         "description": "Return all records"
#       },
#       "complete": {
#         "type": "boolean",
#         "optional": true,
#         "description": "Include extended diagnostics"
#       }
#     }
#
# - @requestExample:
#     Full JSON request body example.
#     Use "none" if the endpoint has no request body.
#
# - @response:
#     Full JSON response body example.
#     Must represent a successful response shape.
#
# - @requires:
#     JSON object or array describing dependencies such as:
#     - environment variables
#     - database tables
#     - indexes
#     - external services
#
# PURPOSE
# This specification defines a uniform documentation block format that ChatGPT
# and automated tooling can use to generate reliable, Swagger-friendly
# documentation for TypeScript, Node.js, Vue, React, and backend API files.
#
# Backward compatibility:
# - v2.1 docblocks remain valid
# - @query is optional
# ---------------------------------------------------------------------------

# ============================================================================
# @myTestingHints — Specification Definition
# ============================================================================
#
# Purpose:
#   @myTestingHints is a structured, comment-based testing guidance block.
#   It documents testing intent, coverage expectations, and behavioral
#   contracts without writing executable test code or binding to a specific
#   test framework.
#
#   It is designed to support deferred testing, AI-assisted test generation,
#   and long-term maintainability.
#
# Design Principles:
#   - No executable code
#   - No framework-specific syntax
#   - Behavior-focused, not implementation-focused
#   - Coverage-aware, not coverage-obsessed
#   - Stable across refactors
#   - Convertible into tests at a later date
#
# Placement Rules:
#   - Appears after the top-level documentation block (e.g. @myDocBlock)
#   - May be applied at file, class, or function scope
#   - One @myTestingHints block per logical unit
#
# Structural Rules:
#   - Uses the host language’s comment syntax
#   - Uses tagged sections (not free-form prose)
#   - Each hint must describe a testable behavior
#   - No nested multiline comments
#
# Canonical Sections:
#
#   @language:
#     - Detected source language (not assumed)
#
#   @runtime:
#     - Execution context (cli | web | library | worker | cron | other)
#
#   @harness:
#     - primary: recommended test framework with coverage support
#     - alternatives: acceptable substitutes
#
#   @coverage:
#     - target: meaningful coverage expectation or rationale
#     - exclude: files, paths, or logic intentionally excluded
#
#   @entryPoints:
#     - Public functions, commands, or invocation targets
#
#   @dependencies:
#     - env: required environment variables
#     - io: filesystem, stdin/stdout, network
#     - external: services, commands, or APIs to be mocked
#
#   @happyPath:
#     - Canonical successful execution scenarios
#
#   @validation:
#     - Input validation rules and rejection cases
#
#   @errorHandling:
#     - Observable failure behavior (exceptions, exit codes, messages)
#
#   @edgeCases:
#     - Boundary conditions and uncommon inputs
#
#   @security:
#     - Trust boundaries, sanitization, injection risks
#
#   @performance:
#     - Constraints or expectations (only if relevant)
#
#   @notes:
#     - Human judgment, rationale, or non-obvious guidance
#
# Non-Goals:
#   - This block does NOT contain test code
#   - This block does NOT mandate a testing framework
#   - This block does NOT restate implementation details
#
# Relationship to @myDocBlock:
#   - @myDocBlock defines what the code is and does
#   - @myTestingHints defines how the code should be tested
#
# ============================================================================
