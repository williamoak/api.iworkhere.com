# === CockroachDB ===
DB_HOST=home.iworkhere.com
DB_PORT=26257
DB_NAME=api
DB_USER=api
DB_CERT_DIR=/data/websites/iworkhere/certs.iworkhere.com/cockroach

# === API Server Certificates ===
API_CERT_DIR=/data/websites/iworkhere/certs.iworkhere.com/api

# === Root CA for mTLS (used by API server for client cert verification) ===
ROOT_CA_CERT=/data/websites/iworkhere/certs.iworkhere.com/ca/ca.crt

NODE_ENV=development

# ---------------------------------------------------------------------------
# @myDocBlock Specification (for importing into ChatGPT or other projects)
# ---------------------------------------------------------------------------
# This standard defines a normalized, strict docblock format suitable for
# Swagger/OpenAPI generation, automated parsing, and consistent documentation.
#
# GENERAL RULES
# - Use standard /** */ docblock format.
# - Never nest multiline comments inside other multiline comments.
# - The following fields must appear in the exact order shown below.
# - requestExample, response, and requires must always contain valid JSON.
# - Use only fully valid JSON (no placeholders, no ellipses, no pseudo-JSON).
# - Code language is never assumed; provide examples only in the language requested.
# - Author tag is always: @author william.r.oak@gmail.com
#
# REQUIRED FIELD ORDER
# 1. @file
# 2. @external
# 3. @module
# 4. @tag
# 5. @version
# 6. @path
# 7. @summary
# 8. @description
# 9. @requestExample
# 10. @response
# 11. @requires
# (Followed by the @author tag)
#
# FIELD NOTES
# - @file: file or logical unit name.
# - @external: external systems or integrations ("none" if not applicable).
# - @module: logical module name.
# - @tag: unique identifier for grouping.
# - @version: semantic version.
# - @path: HTTP path for endpoints, "none" if not an endpoint.
# - @summary: short description (1–2 sentences).
# - @description: longer explanation, multi-line allowed, no nested comments.
# - @requestExample: full JSON request body, or "none".
# - @response: full JSON response body, or "none".
# - @requires: JSON object or array describing dependencies (env, files, network).
#
# PURPOSE
# This specification defines a uniform documentation block format that ChatGPT
# can use to generate reliable, Swagger-friendly docblocks for TypeScript,
# Node.js, Vue, React, and backend API files.
# ---------------------------------------------------------------------------
