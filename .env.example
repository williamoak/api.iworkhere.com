# Example environment variables for local development and tests
# DO NOT commit secret values in real projects. This is an example only.

NODE_ENV=development
PORT=3000
HOST_IP=127.0.0.1

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iworkhere_dev
DB_USER=postgres # not a real user, this is an example file
DB_PASSWORD=postgres # not a real password, this is an example file

# Auth / token TTLs (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=86400

# API
API_VERSION=v1
MAX_CONCURRENT_REQUESTS=10

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

