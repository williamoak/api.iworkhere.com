# Example environment variables for local development and tests
# DO NOT commit secret values in real projects. This is an example only.

NODE_ENV=development
PORT=3000
HOST_IP=127.0.0.1

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iworkhere_dev
DB_USER=postgres # not a real user, this is an example file
DB_PASSWORD=postgres # not a real password, this is an example file

# Auth / token TTLs (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=86400

# API
API_VERSION=v1
MAX_CONCURRENT_REQUESTS=10

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

#oAuth2 **** NOTE: all urls need ot use https ****
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
GOOGLE_OAUTH_REDIRECT_URI=https://api.iworkhere.com/v1/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_STATE_SECRET=long-shared-secret-text

GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=https://api.iworkhere.com/auth/oauth/success
GOOGLE_OAUTH_FAILURE_REDIRECT_URL=https://api.iworkhere.com/auth/oauth/failure
