# Test environment variables for vitest
# Keep non-secret defaults suitable for local CI and developer machines
# Token lifetimes (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=86400

# Other helpful defaults
API_VERSION=v1
MAX_CONCURRENT_REQUESTS=10
# Enable verbose debug for auth.me endpoint during tests if desired
# AUTH_ME_DEBUG=1

