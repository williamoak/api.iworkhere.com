NODE_ENV=test
PORT=3000
HOST_IP=127.0.0.1

DB_HOST=localhost
DB_PORT=5432
DB_NAME=iworkhere_test
DB_USER=api_test

ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=86400
API_VERSION=v1
MAX_CONCURRENT_REQUESTS=10

OAUTH_STATE_SECRET=test-state-secret-12345678901234567890

GOOGLE_OAUTH_CLIENT_ID=test-google-id
GOOGLE_OAUTH_CLIENT_SECRET=test-google-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/callback
GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo

GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=/success
GOOGLE_OAUTH_FAILURE_REDIRECT_URL=/failure
