# Test environment variables for vitest
# Keep non-secret defaults suitable for local CI and developer machines
# Token lifetimes (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=86400

# Other helpful defaults
API_VERSION=v1
MAX_CONCURRENT_REQUESTS=10
# Enable verbose debug for auth.me endpoint during tests if desired
# AUTH_ME_DEBUG=1

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=test-client-id
GOOGLE_OAUTH_CLIENT_SECRET=test-client-secret
GOOGLE_OAUTH_REDIRECT_URI=test-redirect-uri
GOOGLE_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v2/userinfo
OAUTH_STATE_SECRET=test-state-secret
GOOGLE_OAUTH_SUCCESS_REDIRECT_URL=/success
GOOGLE_OAUTH_FAILURE_REDIRECT_URL=/failure
