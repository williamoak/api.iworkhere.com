{
  "name": "api.iworkhere.com",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/start.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/start.js",
    "swagger:gen": "tsx src/helpers/swaggerGen.ts",
    "test": "vitest run --silent",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "seed:data": "tsx src/db/seeds/run.ts",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:apply": "drizzle-kit migrate",
    "drizzle:check": "drizzle-kit check",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "setup:hooks": "git config core.hooksPath .github/hooks && chmod +x .github/hooks/*",
    "prepare": "npm run setup:hooks"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "nodemailer": "^8.0.9",
    "pg": "^8.16.3",
    "rg": "^0.0.2",
    "swagger-ui-express": "^5.0.1",
    "undici": "^7.16.0",
    "uuid": "^13.0.0",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.16.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mock-fs": "^5.5.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.8"
  }
}
