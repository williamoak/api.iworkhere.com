{
  "name": "api.iworkhere.com",
  "version": "1.0.0",
  "type": "module",

  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --exec \"tsx -r tsconfig-paths/register src/server.ts\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "swaggerGen": "tsx -r tsconfig-paths/register ./src/helpers/swaggerGen.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },

  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "undici": "^7.16.0"
  },

  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.13",
    "@vitest/ui": "^4.0.13",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.13"
  }
}
