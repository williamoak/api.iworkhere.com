{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "composite": true,
    "incremental": true,

    "baseUrl": "./src",
    "paths": {
      "@src/*": ["*"],
      "@helpers/*": ["helpers/*"],
      "@services/*": ["services/*"],
      "@controllers/*": ["controllers/*"],
      "@models/*": ["models/*"],
      "@middleware/*" : ["middleware/*"],
      "@loaders/*" : ["loaders/*"],
      "@utils/*": ["utils/*"],
      "@routes/*": ["routes/*"],
      "@schemas/*": ["schemas/*"],
      "@tests/*" : ["../tests/*"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ]
}
